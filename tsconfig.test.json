{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./.omx/tmp/test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "incremental": false,
    "isolatedModules": false,
    "paths": {
      "@vibe-grid/core": ["packages/core/src/index.ts"],
      "@vibe-grid/i18n": ["packages/i18n/src/index.ts"],
      "@vibe-grid/react": ["packages/react/src/index.ts"]
    }
  },
  "include": [
    "packages/clipboard/src/**/*.test.ts",
    "packages/core/src/**/*.test.ts",
    "packages/excel/src/**/*.test.ts",
    "packages/persistence/src/**/*.test.ts",
    "packages/react/src/**/*.test.ts"
  ]
}
