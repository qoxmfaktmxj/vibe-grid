{
  "name": "@vibe-grid/react",
  "version": "0.1.0",
  "description": "Business-grade React data grid (row-first, IBSheet-replacement-oriented)",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/qoxmfaktmxj/vibe-grid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qoxmfaktmxj/vibe-grid.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/qoxmfaktmxj/vibe-grid/issues",
  "keywords": ["grid", "datagrid", "react", "tanstack", "ibsheet", "vibe-grid"],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@vibe-grid/core": "0.1.0",
    "@vibe-grid/i18n": "0.1.0",
    "@vibe-grid/tanstack-adapter": "0.1.0",
    "@vibe-grid/theme-shadcn": "0.1.0",
    "@vibe-grid/virtualization": "0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
