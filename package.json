{
  "name": "vibe-grid",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "author": "minseok kim",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qoxmfaktmxj/vibe-grid.git"
  },
  "homepage": "https://github.com/qoxmfaktmxj/vibe-grid#readme",
  "bugs": "https://github.com/qoxmfaktmxj/vibe-grid/issues",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/playground",
    "apps/bench",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:playground",
    "dev:playground": "npm run dev -w @vibe-grid/playground",
    "dev:bench": "npm run dev -w @vibe-grid/bench",
    "start": "npm run start -w @vibe-grid/playground",
    "build:playground": "npm run build -w @vibe-grid/playground",
    "build:bench": "npm run build -w @vibe-grid/bench",
    "build": "npm run build:playground && npm run build:bench",
    "test:core": "node scripts/run-core-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/hub-smoke.spec.ts tests/e2e/compatibility.spec.ts tests/e2e/bench.spec.ts",
    "test:e2e:local": "npm run build:playground && playwright test",
    "lint:packages": "eslint packages --ext .ts,.tsx",
    "lint:playground": "npm run lint -w @vibe-grid/playground",
    "lint:bench": "npm run lint -w @vibe-grid/bench",
    "lint": "npm run lint:packages && npm run lint:playground && npm run lint:bench",
    "clean:packages": "npm run clean -ws --if-present",
    "build:packages": "npm run build -ws --if-present",
    "prepublishOnly": "npm run lint && npm run build:packages && npm run test:core",
    "ci": "npm run lint && npm run build && npm run test:core && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.8.2"
  }
}
